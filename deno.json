{
  "name": "@erickmerchant/icons",
  "version": "0.1.0",
  "exports": {
    "./icons/check": "./icons/check.ts",
    "./icons/date": "./icons/date.ts",
    "./icons/delete": "./icons/delete.ts",
    "./icons/edit": "./icons/edit.ts",
    "./icons/file": "./icons/file.ts",
    "./icons/folder": "./icons/folder.ts",
    "./icons/pinned": "./icons/pinned.ts",
    "./icons/rss": "./icons/rss.ts"
  },
  "tasks": {
    "dev": "deno run -A --watch-hmr flint.ts --port=4000",
    "build": "deno run -A flint.ts --build",
    "stage": {
      "command": "deno serve -A --port=4000 --parallel dist/serve.ts",
      "dependencies": ["build"]
    }
  },
  "imports": {
    "@flint/framework": "jsr:@flint/framework@^0.37.0",
    "@handcraft/lib": "jsr:@handcraft/lib@^4.4.1",
    "@std/fs": "jsr:@std/fs@^1.0.24"
  },
  "unstable": ["bundle"],
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns",
      "deno.unstable",
      "es2023"
    ]
  }
}
