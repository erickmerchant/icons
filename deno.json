{
  "name": "@erickmerchant/icons",
  "version": "0.2.0",
  "license": "MIT",
  "exports": {
    "./check": "./icons/check.ts",
    "./date": "./icons/date.ts",
    "./delete": "./icons/delete.ts",
    "./edit": "./icons/edit.ts",
    "./file": "./icons/file.ts",
    "./folder": "./icons/folder.ts",
    "./pinned": "./icons/pinned.ts",
    "./rss": "./icons/rss.ts"
  },
  "tasks": {
    "dev": "deno run -A --watch-hmr flint.ts --port=4000",
    "build": "deno run -A flint.ts --build",
    "stage": {
      "command": "deno serve -A --port=4000 --parallel dist/serve.ts",
      "dependencies": ["build"]
    }
  },
  "imports": {
    "@flint/framework": "jsr:@flint/framework@^0.38.0",
    "@handcraft/lib": "jsr:@handcraft/lib@^4.5.0",
    "@std/fs": "jsr:@std/fs@^1.0.24"
  },
  "unstable": ["bundle"],
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns",
      "deno.unstable",
      "es2023"
    ]
  }
}
